# Copy to `.env` and fill values. Used by `forge script ... --broadcast`.
#
# Notes:
# - Values are read via `vm.env*` in `script/*.s.sol`
# - Amounts are in smallest token units (raw ERC-20 units)

#######################################################################
# Shared / core
#######################################################################

# EOA private key used for deployment & authority-only actions.
# Forge accepts either a decimal uint or 0x-prefixed hex.
# Example: PRIVATE_KEY=0x0123...abcd
PRIVATE_KEY=

# Deployed FixedVault address.
VAULT=

#######################################################################
# Pool creation (script/CreatePool.s.sol)
#######################################################################

# ERC-20 token address accepted as deposits.
DEPOSIT_TOKEN=

# APR in basis points. Example: 800 = 8%
APR_BPS=800

# Seconds from now until pool maturity (block.timestamp + offset).
# Example: 2592000 = 30 days
MATURITY_OFFSET_SECONDS=2592000

# Optional: seconds before maturity after which deposits close. 0 = no early deadline.
DEPOSIT_DEADLINE_OFFSET=0

# Minimum deposit amount (uint64) in token smallest units.
MIN_DEPOSIT=

# Pool cap (uint64) in token smallest units.
MAX_TOTAL_DEPOSIT=

# Optional: enable whitelist checks in the vault (true/false).
WHITELIST_ENABLED=false

#######################################################################
# User actions (script/DepositToPool.s.sol, script/WithdrawFromPool.s.sol)
#######################################################################

# Depositor / yToken holder private key (no 0x prefix).
USER_PRIVATE_KEY=

# Pool identifier (uint64).
POOL_ID=

# For DepositToPool: deposit token amount (uint64) in smallest units.
# For WithdrawFromPool: yToken amount to burn (uint64) in smallest units.
# For RepayToPool: deposit token amount (uint64) in smallest units.
AMOUNT=

#######################################################################
# Authority transfer (script/ProposeAuthority.s.sol)
#######################################################################

# Address proposed as the new authority.
NEW_AUTHORITY=

#######################################################################
# Pool updates (script/UpdatePool.s.sol)
#######################################################################

# All updates are optional and gated by UPDATE_* flags (true/false).
UPDATE_MAX_TOTAL_DEPOSIT=false
NEW_MAX_TOTAL_DEPOSIT=

UPDATE_MIN_DEPOSIT=false
NEW_MIN_DEPOSIT=

UPDATE_APR_BPS=false
NEW_APR_BPS=

UPDATE_ALLOW_OVERPAY=false
NEW_ALLOW_OVERPAY=false

